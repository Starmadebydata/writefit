# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# 允许 .env.example 提交（这是模板文件，不含真实密钥）
!.env.example

# vercel
.vercel

# cloudflare open-next build output
/.open-next/

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright MCP debug artifacts
.playwright-mcp/
