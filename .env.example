# ====================================================================
# WriteFit 环境变量模板
# ====================================================================
# 使用方法：
# 1. 复制这个文件为 .env
# 2. 填入真实的值
#
# cp .env.example .env
# ====================================================================

# ---- Auth.js 登录系统 ----
# 生成密钥：openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth 应用：https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth 应用：https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 应用 URL
# 本地开发：http://localhost:3000
# 生产环境：https://writefit.app
NEXTAUTH_URL=http://localhost:3000

# ---- DeepSeek AI ----
# 获取 API Key：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ---- Cloudflare D1 数据库 ----
# 本地开发时不需要填，wrangler 会自动处理
# 部署时在 Cloudflare Dashboard 中配置

# ---- PostHog 产品分析（可选）----
# 不配置则完全静默，不加载 posthog-js
# 获取 Key：https://posthog.com/ 的项目设置
NEXT_PUBLIC_POSTHOG_KEY=
# 默认 https://us.i.posthog.com，EU 区用 https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=

# ---- 平台托管 AI Key（付费墙：免费限量 / 付费分级）----
# 配置后，未自带 Key 的用户用平台 Key 调用 AI（按套餐每日限量）；
# 不配置则回退模拟反馈（保持本地开发体验）
# 生产环境用 wrangler secret 或 Cloudflare Dashboard 变量配置
PLATFORM_AI_API_KEY=
# 可选，默认 https://api.deepseek.com/v1
PLATFORM_AI_BASE_URL=
# 可选，默认 deepseek-chat
PLATFORM_AI_MODEL=

# ---- 匿名访客配额盐（首页试用区 / /practice/dev 演示页）----
# 未登录访客每 IP 每天可用 2 次真实 AI 诊断，用 SHA-256(IP+盐+日期) 计量。
# 缺失时匿名请求自动回退模拟反馈，不影响本地开发。
# 生产环境用 wrangler secret put ANON_QUOTA_SALT 配置，任意随机字符串即可：
# openssl rand -hex 16
ANON_QUOTA_SALT=

# ---- 邮件发送 ----
# 生产环境首选 Cloudflare Email Service（wrangler.jsonc 的 send_email binding，
# 无需任何 Key，Workers Paid + 域名绑定后自动生效）
# Resend 作为兜底（可选）：获取 Key：https://resend.com/
RESEND_API_KEY=
# 可选。CF 发信默认 noreply@writefit.app；Resend 默认 onboarding@resend.dev
EMAIL_FROM=

# ---- PayPal 支付 ----
# developer.paypal.com 创建应用获得；sandbox 用测试凭证，live 用正式凭证
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox = 测试环境（api-m.sandbox.paypal.com）；其余值（含缺省）= 生产
PAYPAL_ENV=sandbox
# PayPal 后台注册 webhook 后获得
PAYPAL_WEBHOOK_ID=
# 订阅计划 ID（在 PayPal 商户后台 UI 创建后，用 scripts/paypal-setup.mjs 查看映射）
PAYPAL_PLAN_BASIC_MONTHLY=
PAYPAL_PLAN_BASIC_YEARLY=
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_YEARLY=
